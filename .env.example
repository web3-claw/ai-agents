# =============================================
# Web3 Claw AI Agents — Configuration
# =============================================
# Copy this file: cp .env.example .env
# Then edit with YOUR values

# =============================================
# YOUR REFERRAL ID
# =============================================
# Default: 126 (Web3 Claw official)
# After you register at web3sonic.com/register,
# change this to YOUR ID number.
# That's it — all content will promote YOUR referral link.
WEB3_SONIC_ID=126

# =============================================
# LLM Provider (pick one)
# =============================================

# Option 1: NVIDIA NIM (FREE — recommended to start)
# Get key at: https://build.nvidia.com
NVIDIA_API_KEY=
LLM_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# Option 2: LiteLLM Proxy (recommended for multi-model)
# LLM_ENDPOINT=http://127.0.0.1:4000/v1/chat/completions
# LLM_API_KEY=

# Option 3: OpenAI
# LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# Option 4: xAI Grok
# LLM_ENDPOINT=https://api.x.ai/v1/chat/completions
# LLM_API_KEY=xai-...
# LLM_MODEL=grok-3

# =============================================
# Platform Credentials (optional — enable what you need)
# =============================================

# YouTube (for auto-uploading Shorts)
# Run: python -m content_engine.publisher setup-youtube
YOUTUBE_CLIENT_SECRETS=~/.config/content_engine/youtube_client_secrets.json
YOUTUBE_TOKEN_PATH=~/.config/content_engine/youtube_token.json

# Paragraph.com (for publishing articles)
# Get key at: https://paragraph.com → Settings → API
PARAGRAPH_API_KEY=

# Matrix / WhatsApp Bridge (for WhatsApp posting)
MATRIX_BASE=https://matrix.your-server.com
MATRIX_ADMIN_TOKEN=
WHATSAPP_ROOM_ID=

# =============================================
# Video Generation (optional — for YouTube Shorts)
# =============================================

# xAI Grok (image + video generation)
XAI_API_KEY=

# NVIDIA Cosmos (video generation)
# Uses same NVIDIA_API_KEY above

# =============================================
# Advanced Settings
# =============================================

# Content output directory
CONTENT_ENGINE_OUTPUT_DIR=/tmp/content_engine_output

# Lock files for dedup
CONTENT_ENGINE_LOCK_DIR=/tmp/content_engine_locks

# Scheduler state
CONTENT_ENGINE_STATE=/tmp/content_engine_state.json

# LLM temperature (0.0-1.0, higher = more creative)
LLM_TEMPERATURE=0.8

# Max tokens per LLM response
LLM_MAX_TOKENS=1000
